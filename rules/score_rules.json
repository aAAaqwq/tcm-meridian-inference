{
  "version": "2.2",
  "notes": "调整评分区间：90-100优秀，80-90亚健康，70-80需注意，60-70严重，保底60分",
  "base_score": 100,
  "min_score": 60,
  "max_score": 100,
  "balance_threshold": 0.2,
  "severity_thresholds": {
    "mild_max": 0.5,
    "medium_max": 1.0
  },
  "deductions": [
    { "rule_id": "single_meridian_mild_abnormal", "condition": "severity == mild", "per_meridian": true, "score": -1.0, "note": "轻度异常单经络扣1分" },
    { "rule_id": "single_meridian_medium_abnormal", "condition": "severity == medium", "per_meridian": true, "score": -2.0, "note": "中度异常单经络扣2分" },
    { "rule_id": "single_meridian_high_abnormal", "condition": "severity == high", "per_meridian": true, "score": -4.0, "note": "高度异常单经络扣4分" },
    { "rule_id": "single_meridian_cross", "condition": "cross == true", "per_meridian": true, "score": -2.0, "note": "交叉异常单经络扣2分" },
    { "rule_id": "kidney_bladder_double_cross", "condition": "kidney.cross AND bladder.cross", "per_meridian": false, "score": -3, "note": "肾膀胱双交叉扣3分" },
    { "rule_id": "multi_cross", "condition": "cross_count >= 3", "per_meridian": false, "score": -3, "note": "3个以上交叉扣3分" },
    { "rule_id": "right_bias", "condition": "right_low_count_before >= 4 OR right_low_count_after >= 4", "per_meridian": false, "score": -4, "note": "右偏扣4分" },
    { "rule_id": "left_bias", "condition": "left_low_count_before >= 4 OR left_low_count_after >= 4", "per_meridian": false, "score": -4, "note": "左偏扣4分" },
    { "rule_id": "heart_supply_hit", "condition": "combo_heart_supply in hits", "per_meridian": false, "score": -4, "note": "心脑供血风险扣4分" },
    { "rule_id": "head_supply_hit", "condition": "combo_head_supply in hits", "per_meridian": false, "score": -4, "note": "头部供血风险扣4分" },
    { "rule_id": "neck_waist_reproductive_hit", "condition": "combo_neck OR combo_waist OR combo_reproductive in hits", "per_meridian": false, "score": -3, "note": "颈腰生殖风险扣3分" },
    { "rule_id": "mass_risk_hit", "condition": "combo_liver_gall_spleen_mass in hits", "per_meridian": false, "score": -4, "note": "肿块风险扣4分" },
    { "rule_id": "multi_imbalance", "condition": "abnormal_meridian_count >= 4", "per_meridian": false, "score": -4, "note": "4个以上经络失衡扣4分" }
  ],
  "bonuses": [
    { "rule_id": "multiple_meridians_improved", "condition": "improved_count >= 3", "score": 4, "note": "3个以上经络改善加4分" },
    { "rule_id": "partial_improvement", "condition": "improved_count >= 1 AND improved_count < 3", "score": 2, "note": "部分改善加2分" },
    { "rule_id": "overall_stable", "condition": "no_cross AND abnormal_count <= 2", "score": 3, "note": "整体平稳加3分" }
  ],
  "score_levels": [
    { "min": 90, "max": 100, "level": "健康优秀", "summary": "当前整体状态优秀，请继续保持。", "category": "优秀" },
    { "min": 80, "max": 89, "level": "轻度失衡", "summary": "整体状态尚可，局部仍需关注。", "category": "亚健康" },
    { "min": 70, "max": 79, "level": "中度失衡", "summary": "存在较明确失衡，建议持续调理。", "category": "需注意" },
    { "min": 60, "max": 69, "level": "严重问题", "summary": "当前失衡较明显，建议尽早重视。", "category": "严重" }
  ]
}
